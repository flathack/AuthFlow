<Window x:Class="AutoLogin.App.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="AuthFlow Browser"
        Height="760"
        Width="1180"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Loaded="Window_Loaded">
    <Border Background="{StaticResource ThemeWindowBrush}"
            BorderBrush="{StaticResource ThemeBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource ThemeAlternateBaseBrush}"
                    BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <TextBlock Margin="0"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{StaticResource ThemeWindowTextBrush}"
                                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="-"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="MinimizeButton_Click" />
                        <Button Content="□"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="MaximizeButton_Click" />
                        <Button Content="X"
                                Style="{StaticResource CloseTitleBarButtonStyle}"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource ThemeWindowBrush}"
                    BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12">
                <DockPanel>
                    <StackPanel>
                        <TextBlock x:Name="HeaderTextBlock" Foreground="{StaticResource ThemeWindowTextBrush}" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="SubHeaderTextBlock" Margin="0,6,0,0" Foreground="{StaticResource ThemeSublineBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="Neu laden" Padding="14,5" Height="38" Margin="10,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ReloadButton_Click" />
                        <Button Content="Automation ausführen" Padding="14,5" Height="38" Margin="10,0,0,0" Click="RunAutomationButton_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource ThemeBaseBrush}">
                <wv2:WebView2 x:Name="BrowserView" />
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource ThemeAlternateBaseBrush}"
                    BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12">
                <TextBlock x:Name="ExecutionStatusTextBlock" Foreground="{StaticResource ThemeSublineBrush}" Text="Bereit." TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Border>
</Window>
