<Window x:Class="AutoLogin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AuthFlow"
        Height="360"
        Width="640"
        MinHeight="340"
        MinWidth="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Loaded="Window_Loaded">
    <Border Background="{StaticResource ThemeWindowBrush}"
            BorderBrush="{StaticResource ThemeBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource ThemeWindowBrush}"
                    BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <TextBlock Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{StaticResource ThemeWindowTextBrush}"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button DockPanel.Dock="Right"
                            Content="X"
                            Style="{StaticResource CloseTitleBarButtonStyle}"
                            Click="CloseButton_Click" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="20"
                    Padding="22"
                    Background="{StaticResource ThemeAlternateBaseBrush}"
                    BorderBrush="{StaticResource ThemeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel>
                            <TextBlock Text="AuthFlow"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeWindowTextBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource ThemeSublineBrush}"
                                       Text="Login-Ziel wählen und Automation starten" />
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Padding="4"
                                Background="{StaticResource ThemeBaseBrush}"
                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="+"
                                        Width="44"
                                        Height="38"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        ToolTip="Neuen Eintrag anlegen"
                                        Click="AddButton_Click" />
                                <Button Content="Bearbeiten"
                                        Width="104"
                                        Height="38"
                                        Padding="10,3"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="EditButton_Click" />
                            </StackPanel>
                        </Border>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,24,0,8"
                               Foreground="{StaticResource ThemeSublineBrush}"
                               Text="Eintrag auswählen" />

                    <ComboBox x:Name="EntriesComboBox"
                              Grid.Row="2"
                              Height="46"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="EntriesComboBox_SelectionChanged" />

                    <StackPanel Grid.Row="3"
                                Margin="0,22,0,0">
                        <Button Content="Anmelden"
                                Height="58"
                                Padding="12,4"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Click="LoginButton_Click" />

                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource ThemeSublineBrush}"
                                   Text="Bereit."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
